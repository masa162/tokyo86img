{
  "name": "tokyo86",
  "version": "1.0.0",
  "description": "tokyo86 - Hono based Comic & Illustration Platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=@tokyo86/api",
    "dev:admin": "npm run dev --workspace=@tokyo86/admin",
    "dev:public": "npm run dev --workspace=@tokyo86/public",
    "dev:img-cdn": "npm run dev --workspace=@tokyo86/img-cdn",
    "deploy:api": "npm run deploy --workspace=@tokyo86/api",
    "deploy:admin": "npm run deploy --workspace=@tokyo86/admin",
    "deploy:public": "npm run deploy --workspace=@tokyo86/public",
    "deploy:img-cdn": "npm run deploy --workspace=@tokyo86/img-cdn",
    "build": "npm run build --workspaces"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "wrangler": "^3.0.0"
  }
}
